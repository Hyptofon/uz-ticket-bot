# Telegram Bot Token (отримати у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID(s) дозволених користувачів (через кому)
# Дізнатися свій chat_id: запустити бота, він виведе в консоль при першому /start
ALLOWED_CHAT_IDS=123456789

# База даних
DATABASE_PATH=./data/bot.db

# УЗ API
UZ_BASE_URL=https://booking.uz.gov.ua

# Інтервал полінгу (секунди) — базовий для одного монітора
POLL_INTERVAL_SEC=90

# Нічне уповільнення (тільки для status=active, НЕ для found!)
NIGHT_THROTTLE_ENABLED=true
NIGHT_THROTTLE_START=01:00
NIGHT_THROTTLE_END=05:00
NIGHT_THROTTLE_INTERVAL_SEC=600

# Alert Engine — інтервали ескалації (секунди)
ALERT_INSTANT_DELAY_SEC=0
ALERT_ESCALATION1_INTERVAL_SEC=25
ALERT_ESCALATION1_DURATION_SEC=300
ALERT_ESCALATION2_INTERVAL_SEC=60
ALERT_ESCALATION2_DURATION_SEC=1500
ALERT_STEADY_INTERVAL_SEC=300
ALERT_NIGHT_QUIET_ENABLED=false

# Кількість збоїв поспіль до переходу в статус error
MAX_CONSECUTIVE_FAILURES=10

# Логування
LOG_LEVEL=info

# Timezone
TZ=Europe/Kyiv
