          "content": {
            "size": 472,
            "mimeType": "x-unknown",
            "text": "let timer = null;\n\nself.addEventListener('message', (e) => {\n    const { data } = e;\n\n  if (timer) {\n    clearInterval(timer);\n      timer = null;\n  }\n\n    if (data <= 0) {\n        return;\n    }\n\n  let time = data;\n  self.postMessage(time);\n\n  timer = setInterval(() => {\n    time -= 1000; // subtract a second\n    if (time <= 0) {\n      self.postMessage(0);\n      clearInterval(timer);\n      timer = null;\n    } else {\n      self.postMessage(time);\n    }\n  }, 1000);\n});\n"
          },
          "redirectURL": "",
