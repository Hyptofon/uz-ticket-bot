            "text": "{\"header_notice\":null,\"banners\":[{\"background_style\":\"background: linear-gradient(#208CC8 0%, #2398D9 50%, #72CBFC 100%);\",\"background_image\":\"https:\\/\\/app.uz.gov.ua\\/storage\\/web-images\\/pCtD0jkaLw.png\",\"text_color\":\"#ffffff\",\"title\":\"\\u0429\\u043e\\u0434\\u0435\\u043d\\u043d\\u0456 \\u0440\\u0435\\u0439\\u0441\\u0438 \\u0434\\u043e \\u041a\\u0438\\u0448\\u0438\\u043d\\u0435\\u0432\\u0430\",\"description\":\"\\u041f\\u043b\\u0430\\u043d\\u0443\\u0432\\u0430\\u0442\\u0438 \\u043f\\u043e\\u0434\\u043e\\u0440\\u043e\\u0436\\u0456 \\u0449\\u0435 \\u043f\\u0440\\u043e\\u0441\\u0442\\u0456\\u0448\\u0435.\\r\\n\\u0428\\u0432\\u0438\\u0434\\u043a\\u0438\\u0439 \\u0448\\u043b\\u044f\\u0445 \\u0434\\u043e \\u043c\\u0456\\u0436\\u043d\\u0430\\u0440\\u043e\\u0434\\u043d\\u043e\\u0433\\u043e \\u0430\\u0435\\u0440\\u043e\\u043f\\u043e\\u0440\\u0442\\u0443.\",\"button\":{\"title\":\"\\u041f\\u0435\\u0440\\u0435\\u0433\\u043b\\u044f\\u043d\\u0443\\u0442\\u0438\",\"url\":\"https:\\/\\/booking.uz.gov.ua\\/search-trips\\/2200001\\/2300000\\/list\"}},{\"background_style\":\"background: linear-gradient(105.98deg, #2B9CD0 0%, #0E6293 74.74%);\",\"background_image\":\"https:\\/\\/app.uz.gov.ua\\/storage\\/web-images\\/LRrGXMoOKw.png\",\"text_color\":\"#ffffff\",\"title\":\"\\u041a\\u0432\\u0438\\u0442\\u043a\\u0438 \\u043d\\u0430 \\u0414\\u0438\\u0442\\u044f\\u0447\\u0443 \\u0417\\u0430\\u043b\\u0456\\u0437\\u043d\\u0438\\u0446\\u044e\",\"description\":\"\\u0417\\u0430\\u0445\\u043e\\u043f\\u043b\\u0438\\u0432\\u0430 \\u043f\\u043e\\u0434\\u043e\\u0440\\u043e\\u0436 \\u043c\\u0456\\u0441\\u0442\\u043e\\u043c \\u0434\\u043b\\u044f \\u0432\\u0441\\u0456\\u0454\\u0457 \\u0440\\u043e\\u0434\\u0438\\u043d\\u0438\",\"button\":{\"title\":\"\\u041f\\u0440\\u0438\\u0434\\u0431\\u0430\\u0442\\u0438 \\u043a\\u0432\\u0438\\u0442\\u043a\\u0438\",\"url\":\"https:\\/\\/booking.uz.gov.ua\\/kids\"}},{\"background_style\":\"background: linear-gradient(#1B3A57